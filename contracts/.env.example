# ─── Moteur Blockchain (Alchemy) ──────────────────────────
# 1. Allez sur https://dashboard.alchemy.com/
# 2. Créez des applications pour "Ethereum Sepolia" et "Base Sepolia"
ALCHEMY_SEPOLIA_RPC="<remplacer_par_l_URL_https_eth_sepolia_g_alchemy_v2_...>"
ALCHEMY_BASE_SEPOLIA_RPC="<remplacer_par_l_URL_https_base_sepolia_g_alchemy_v2_...>"

# ─── Portefeuille de Déploiement (MetaMask) ───────────────
# ⚠️ Ne mettez JAMAIS la clé privée d'un compte avec de vrais fonds ! Utilisez un compte de test.
# Exportez la clé privée depuis MetaMask (Paramètres > Sécurité)
DEPLOYER_PRIVATE_KEY="<remplacer_par_votre_cle_privee_metamask>"

# ─── Adresses d'Administration de la Maison Horlogère ──────
# L'adresse publique de votre portefeuille (ex: 0xFF...)
MAISON_ADMIN_ADDRESS="<remplacer_par_votre_adresse_publique_ethereum_0x...>"
# Le co-signataire pour les transferts de haute valeur (peut être la même adresse pour tester)
MAISON_CO_SIGNER="<remplacer_par_l_adresse_du_co_signataire_0x...>"

# ─── Vérification du Code Bilan (Optionnel) ────────────────
# Clés API pour que le code source soit lisible sur les explorateurs
ETHERSCAN_API_KEY="<remplacer_par_votre_cle_api_etherscan_pour_sepolia>"
BASESCAN_API_KEY="<remplacer_par_votre_cle_api_basescan_pour_base_sepolia>"
